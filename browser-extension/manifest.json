{
  "manifest_version": 3,
  "name": "LLMask Privacy Shield",
  "version": "1.0.0",
  "description": "Masks sensitive data (PII, secrets, org names) before sending to ChatGPT and Claude, then remaps responses back.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LLMask Privacy Shield"
  }
}
