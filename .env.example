# ==========================================
# LLMask Configuration
# ==========================================

# Server
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# ==========================================
# Provider Configuration
# ==========================================

# Primary provider: openai | anthropic | gemini | mistral | azure-openai
PRIMARY_PROVIDER=openai

# Fallback provider (optional): openai | anthropic | gemini | mistral | litellm
FALLBACK_PROVIDER=

# ==========================================
# OpenAI Configuration
# ==========================================

# Authentication mode: api_key | oauth_codex
OPENAI_AUTH_MODE=api_key

# API key (required if auth_mode=api_key)
OPENAI_API_KEY=

# Base URL
# - api_key mode: https://api.openai.com
# - oauth_codex mode: https://chatgpt.com/backend-api
OPENAI_BASE_URL=https://api.openai.com

# OAuth token path (required if auth_mode=oauth_codex)
# Default: ~/.codex/auth.json
OPENAI_OAUTH_TOKEN_PATH=

# ==========================================
# Anthropic Configuration
# ==========================================

# Authentication mode: api_key | oauth_claude_code
ANTHROPIC_AUTH_MODE=api_key

# API key (required if auth_mode=api_key)
ANTHROPIC_API_KEY=

# Base URL
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# OAuth token path (required if auth_mode=oauth_claude_code)
# Default: ~/.claude/.credentials.json
ANTHROPIC_OAUTH_TOKEN_PATH=

# ==========================================
# Other Providers
# ==========================================

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=

# ==========================================
# LLMask Behavior
# ==========================================

# Mode: trust (auto-mask) | review (manual approval)
LLMASK_MODE=trust

# Fail-safe: block requests if masking fails
FAIL_SAFE_BLOCK_ON_ERROR=true

# Request timeout (ms)
REQUEST_TIMEOUT_MS=60000

# ==========================================
# Data Storage
# ==========================================

# Local data directory
DATA_DIR=./data

# SQLite database path
SQLITE_PATH=./data/llmask.db

# ==========================================
# Security
# ==========================================

# Rate limiting (requests per IP per minute, 0 = disabled)
LLMASK_RATE_LIMIT=60

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Maximum prompt size (bytes)
MAX_PROMPT_SIZE=102400

# ==========================================
# Advanced Features (Optional)
# ==========================================

# Local LLM for entity extraction (Ollama)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Project Shield (mask project/product names)
PROJECT_SHIELD_PATH=

# Metrics (Prometheus)
METRICS_ENABLED=true
METRICS_PATH=/metrics

# TLS/HTTPS (leave empty for HTTP)
# LLMASK_TLS_CERT=/path/to/cert.pem
# LLMASK_TLS_KEY=/path/to/key.pem
