# ============================================================================
# LLMask — Production Environment Configuration
# Copy this file to deploy/.env and fill in your values.
# ============================================================================

# ── Domain (required for HTTPS via Caddy) ────────────────────────────────────
# The public domain name where LLMask will be accessible.
# Example: llmask.mycompany.com
# Caddy will automatically obtain a free Let's Encrypt certificate for this domain.
LLMASK_DOMAIN=llmask.mycompany.com

# ── Server ────────────────────────────────────────────────────────────────────
# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which AI provider to route requests to.
# Supported: openai | anthropic | gemini | mistral | azure-openai | litellm
PRIMARY_PROVIDER=openai

# Optional fallback provider if primary is unavailable.
FALLBACK_PROVIDER=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Mistral AI ────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
# Example: https://my-resource.openai.azure.com
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_API_VERSION=2024-10-21
# The name of your deployed model (e.g. gpt-4o)
AZURE_OPENAI_DEPLOYMENT=

# ── LLM-based entity extraction (optional, local Ollama) ──────────────────────
# Enable to use a local model for smarter entity detection (no data sent externally).
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# ── LLMask Behavior ───────────────────────────────────────────────────────────
# trust: mask automatically and forward the request.
# review: hold requests for manual approval via the dashboard.
LLMASK_MODE=trust

# Block requests when masking fails (recommended: true for production).
FAIL_SAFE_BLOCK_ON_ERROR=true

# Upstream API timeout in milliseconds.
REQUEST_TIMEOUT_MS=60000

# ── Security ──────────────────────────────────────────────────────────────────
# Rate limit: max requests per IP per minute (0 = disabled).
LLMASK_RATE_LIMIT=60

# CORS: allowed origins for the dashboard and API (comma-separated).
# In production, restrict to your internal tools or leave empty to allow all.
CORS_ORIGINS=

# Maximum prompt size in bytes (default: 100 KB).
MAX_PROMPT_SIZE=102400

# ── Dashboard authentication ──────────────────────────────────────────────────
# Set to true and provide a key to protect the admin dashboard.
LLMASK_AUTH_ENABLED=false
# Generate a strong key: openssl rand -hex 32
LLMASK_ADMIN_KEY=

# ── Metrics (Prometheus) ──────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PATH=/metrics
# Optionally restrict metrics to a bearer token.
METRICS_AUTH_TOKEN=

# ── Project Shield (optional) ────────────────────────────────────────────────
# Path to a JSON file mapping real project names to aliases.
# Example: {"MyProject": "PROJECT_A", "ClientCorp": "CLIENT_1"}
PROJECT_SHIELD_PATH=
