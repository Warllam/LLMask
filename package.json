{
  "name": "llmask",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "OpenAI-compatible proxy that masks sensitive data before it reaches any LLM",
  "keywords": [
    "llm",
    "proxy",
    "anonymization",
    "masking",
    "openai",
    "anthropic",
    "privacy",
    "security",
    "pii",
    "gdpr"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/llmask.git"
  },
  "bin": {
    "llmask": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && cd dashboard && npm run build",
    "build:server": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "tsx scripts/setup.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.7.4",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "web-tree-sitter": "^0.24.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.4.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
